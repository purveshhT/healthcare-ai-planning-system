# =============================================================
# .gitignore — Healthcare AI Planning System
# =============================================================

# ----- Environment / secrets (NEVER commit) -----
.env
*.env

# ----- Python -----
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ----- Virtual environments -----
venv/
.venv/
env/
ENV/

# ----- Jupyter -----
.ipynb_checkpoints/
*.ipynb~

# ----- Data & model outputs (large files) -----
*.csv
*.pkl
*.joblib
*.h5
*.parquet

# ----- OS -----
.DS_Store
Thumbs.db
desktop.ini

# ----- IDE -----
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
